# ============================================================
# Fund Report Agent — 环境变量配置模板
# 复制此文件为 .env，填入真实值（不要提交到 Git！）
# ============================================================

# ── AI Provider (必填) ──────────────────────────────────────
# 阿里云百炼 / DeepSeek / OpenAI / MiniMax 等
DASHSCOPE_API_KEY=sk-your-aliyun-key-here
PROVIDER=aliyun

# ── 搜索工具 (可选) ─────────────────────────────────────────
# Tavily API Key (用于增强搜索)
TAVILY_API_KEY=tvly-your-tavily-key-here

# ── 邮件发送 (必填) ─────────────────────────────────────────
# QQ邮箱 SMTP（也可替换为其他SMTP服务）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=your-email@qq.com
SMTP_PASSWORD=your-16-char-authorization-code

# ── 报告配置 ───────────────────────────────────────────────
# 运行时指定：PROFILE=dad|k7407  TEMPLATE=weekend_recap|weekly_close
PROFILE=dad
TEMPLATE=weekend_recap

# ── 报告输出目录 ────────────────────────────────────────────
FUND_REPORT_OUTPUT=./output
